{
  "framework": "vitepress",
  "buildCommand": "pnpm run docs:build",
  "outputDirectory": "docs/.vitepress/dist",
  "installCommand": "pnpm install",
  "devCommand": "pnpm run docs:dev",
  "header": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}
